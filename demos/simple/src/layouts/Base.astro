---
import { getMenu, getEmDashCollection } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import Melon from "../components/Melon.astro";
import themeStylesheetUrl from "../styles/theme.css?url";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
	/** JSON-LD schema blocks to inject in <head> */
	jsonLd?: Record<string, unknown>[];
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	jsonLd = [],
} = Astro.props;
const siteTitle = "Andrés Ospina";
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

// Fetch primary menu defined in seed
const menu = await getMenu("primary");
const brandMenuItems = [
	{ label: "Sobre mí", url: "/sobre-mi" },
	{ label: "Recursos", url: "/blog" },
	{ label: "Conferencias", url: "/conferencias" },
	{ label: "Eventos", url: "/eventos-ia/" },
	{ label: "Podcast", url: "https://inboundmonsters.com/", target: "_blank" },
	{ label: "Trabaja conmigo", url: "/contacto" },
];
const menuItems = menu?.items ?? [];
const isStarterMenu =
	menuItems.length > 0 &&
	menuItems.every((item) => ["Home", "About", "Posts"].includes(item.label));
const headerMenuItems = menuItems.length > 0 && !isStarterMenu ? menuItems : brandMenuItems;

// Fetch pages for footer
const { entries: pages } = await getEmDashCollection("pages");

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#1A33F6" />
		<link rel="icon" type="image/png" href="/brand/favicon.png" sizes="32x32" />
		<link rel="shortcut icon" type="image/png" href="/brand/favicon.png" />
		<link rel="apple-touch-icon" href="/brand/favicon.png" />
		<link rel="preload" href="/fonts/gilroy-extrabold.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/noto-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="stylesheet" href={themeStylesheetUrl} />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<style is:inline>
			/* Critical CSS — above-the-fold, inlined for first paint */
			@font-face { font-family: "Gilroy-ExtraBold"; src: url("/fonts/gilroy-extrabold.woff2") format("woff2"); font-display: swap; }
			html { scroll-behavior: smooth; scroll-padding-top: 5rem; }
			html, body { margin: 0; padding: 0; }
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: "Noto Sans", -apple-system, BlinkMacSystemFont, sans-serif;
				font-size: 17px;
				line-height: 1.6;
				letter-spacing: -0.01em;
				color: #1d1d1f;
				background: #fff;
				-webkit-font-smoothing: antialiased;
				overflow-x: hidden;
			}
			a { color: #1A33F6; text-decoration: none; }
			img { max-width: 100%; height: auto; display: block; }
			.c { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; }
			main { padding-top: 6rem; min-height: calc(100vh - 400px); }
			/* Header pill — critical for first paint */
			.site-header {
				position: fixed; top: 1rem; left: 50%; transform: translateX(-50%);
				z-index: 100; width: calc(100% - 5rem); max-width: 1120px;
				padding: 0.75rem 1.5rem; border-radius: 999px;
				background: rgba(255,255,255,0.55);
				backdrop-filter: blur(24px) saturate(180%);
				-webkit-backdrop-filter: blur(24px) saturate(180%);
				border: 1px solid rgba(255,255,255,0.35);
				box-shadow: 0 4px 24px rgba(0,0,0,0.06);
			}
			.header-inner { display: flex; align-items: center; justify-content: space-between; }
			.header-logo { display: inline-flex; align-items: center; text-decoration: none; }
			.header-logo img { height: 1.8rem; width: auto; min-width: 80px; max-width: 140px; object-fit: contain; filter: brightness(0); }
			.header-nav { display: flex; align-items: center; gap: 1.6rem; }
			.header-nav a { font-size: 0.82rem; color: rgba(0,0,0,0.45); font-family: "Gilroy-ExtraBold", sans-serif; font-weight: 700; white-space: nowrap; }
			.header-nav .btn-header { background: #1A33F6; color: #fff !important; padding: 0.55rem 1.15rem; border-radius: 999px; font-size: 0.78rem; }
			.hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 8px; z-index: 200; }
			.hamburger span { width: 22px; height: 2px; background: #1d1d1f; border-radius: 2px; }
			.mobile-menu { display: none; position: fixed; inset: 0; z-index: 99; background: rgba(255,255,255,0.97); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); flex-direction: column; align-items: center; justify-content: center; gap: 2rem; }
			.mobile-menu.open { display: flex; }
			.mobile-menu a { font-family: "Gilroy-ExtraBold", sans-serif; font-size: 1.5rem; color: #1d1d1f; text-decoration: none; }
			@media (max-width: 991.98px) {
				.header-nav { display: none; }
				.hamburger { display: flex; }
				.site-header { top: 0.65rem; width: calc(100% - 1.25rem); max-width: 100%; padding: 0.7rem 1rem; border-radius: 999px; }
				.header-logo img { height: 1.65rem; min-width: 74px; }
				.mobile-menu { padding: 6rem 1.5rem 2rem; }
				.mobile-menu a { font-size: clamp(1.35rem, 7vw, 2rem); line-height: 1.08; }
			}
			.site-header.on-dark { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.08); box-shadow: 0 4px 24px rgba(0,0,0,0.4); }
			.site-header.on-dark .header-logo img { filter: brightness(0) invert(1); }
			.site-header.on-dark .header-nav a { color: rgba(255,255,255,0.55); }
			.site-header.on-dark .header-nav a:hover { color: #fff; }
			.site-header.on-dark .header-nav .btn-header { background: #1A33F6; color: #fff !important; }
			.site-header.on-dark .hamburger span { background: #fff; }
			.site-header.on-dark + .mobile-menu { background: rgba(10,10,12,0.97); }
			.site-header.on-dark + .mobile-menu a { color: #f4f4f4; }
			/* Hero + intro (above the fold on post pages) */
			.post-hero {
				--post-hero-bg: #070707;
				--post-hero-ink: #fbf8ef;
				--post-hero-muted: rgba(251, 248, 239, 0.78);
				--post-hero-rule: rgba(245, 242, 232, 0.16);
				--post-hero-accent: #1A33F6;
				--post-hero-kicker: rgba(251, 248, 239, 0.72);
				position: relative;
				isolation: isolate;
				overflow: hidden;
				margin-top: -6rem;
				padding: clamp(7rem, 10vw, 9.5rem) 0 clamp(3rem, 5.5vw, 4.75rem);
				background: linear-gradient(135deg, rgba(255,255,255,0.06), transparent 44%), var(--post-hero-bg);
				color: var(--post-hero-ink);
				border-bottom: 0;
				box-shadow: none;
			}
			.post-hero::before { content: ""; position: absolute; inset: 0; z-index: -2; background: linear-gradient(to right, rgba(245,242,232,0.08) 1px, transparent 1px), linear-gradient(to bottom, rgba(245,242,232,0.08) 1px, transparent 1px); background-size: 72px 72px; -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.68), transparent 76%); mask-image: linear-gradient(180deg, rgba(0,0,0,0.68), transparent 76%); opacity: 0.16; }
			.post-hero .c { position: relative; z-index: 1; }
			.post-hero-grid { display: grid; grid-template-columns: minmax(20rem, 1fr) minmax(0, 1fr); gap: clamp(2rem, 4.6vw, 4.25rem); align-items: center; }
			.post-hero .breadcrumb { margin: 0 0 clamp(1.85rem, 3.4vw, 2.8rem); font-family: "DM Sans", sans-serif; font-size: 0.72rem; color: var(--post-hero-muted); text-transform: uppercase; letter-spacing: 0.07em; }
			.post-hero .breadcrumb a { color: currentColor; font-weight: 700; text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 0.22em; }
			.article-hero { width: 100%; margin: 0; aspect-ratio: 1 / 1; position: relative; isolation: isolate; overflow: visible; border-radius: clamp(18px, 2vw, 28px); border: 1px solid rgba(245,242,232,0.14); background: #0b0b0b; box-shadow: 0 22px 70px rgba(0,0,0,0.34); }
			.article-hero::before { content: ""; position: absolute; inset: -4.5%; z-index: -1; border-radius: calc(clamp(18px, 2vw, 28px) * 1.25); background-image: var(--hero-image-url); background-position: var(--hero-image-position, 50% 50%); background-size: cover; filter: blur(34px) saturate(1.75) contrast(1.06); opacity: 0.56; transform: scale(1.01); pointer-events: none; }
			.article-hero::after { content: ""; position: absolute; inset: 0; z-index: 2; border-radius: inherit; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08), inset 0 1px 0 rgba(255,255,255,0.12); pointer-events: none; }
			.article-hero img { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: cover; object-position: var(--hero-image-position, 50% 50%); border-radius: inherit; margin: 0; border: 0; background: transparent; box-shadow: none; }
			.article-hero--video { aspect-ratio: 16 / 9; background: #020203; }
			.hero-video-frame { position: relative; z-index: 1; width: 100%; height: 100%; overflow: hidden; border-radius: inherit; background: #020203; }
			.hero-video-frame iframe, .hero-video-frame video { display: block; width: 100%; height: 100%; border: 0; border-radius: inherit; background: #020203; }
			.intro-section { max-width: none; padding: 0; }
			.article-kicker { display: flex; flex-wrap: wrap; gap: 0.45rem; align-items: center; margin-bottom: 1.1rem; font-family: "Noto Sans", sans-serif; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--post-hero-kicker); }
			.article-kicker a, .article-kicker span { display: inline-flex; align-items: center; border: 1px solid rgba(251,248,239,0.14); border-radius: 999px; background: rgba(255,255,255,0.035); padding: 0.24rem 0.58rem; color: currentColor; text-decoration: none; transition: border-color 160ms ease, background 160ms ease, color 160ms ease, transform 160ms ease; }
			.article-kicker a:hover { border-color: rgba(251,248,239,0.32); background: rgba(255,255,255,0.075); color: var(--post-hero-ink); transform: translateY(-1px); }
			.article-kicker a::before, .article-kicker span::before { content: none; }
			.intro-section h1.article-title {
				font-family: "Gilroy-ExtraBold", sans-serif;
				font-size: clamp(2.6rem, 4.5vw, 4.55rem);
				color: currentColor;
				letter-spacing: -0.055em;
				line-height: 0.96;
				margin: 0;
				font-weight: 700;
				max-width: 12.5ch;
				text-wrap: balance;
			}
			.intro-section .article-meta {
				font-family: "DM Sans", sans-serif;
				font-size: 0.72rem;
				color: var(--post-hero-muted);
				margin: 1.4rem 0 0;
				display: flex;
				gap: 0.7rem;
				align-items: center;
				flex-wrap: wrap;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				font-weight: 600;
			}
			.intro-section .article-meta .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: currentColor; opacity: 0.45; display: inline-block; }
			.intro-section .article-meta-author { display: inline-flex; align-items: center; gap: 0.55rem; text-decoration: none; border: none; }
			.intro-section .article-meta-avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; flex-shrink: 0; filter: grayscale(100%); }
			.intro-section .article-meta-byline { color: currentColor; font-weight: 700; font-family: "Noto Sans", sans-serif; font-size: 0.88rem; text-transform: none; letter-spacing: normal; }
			.intro-section .article-excerpt { font-size: clamp(1.08rem, 1.55vw, 1.48rem); color: var(--post-hero-muted); line-height: 1.42; margin: 1.2rem 0 0; font-weight: 400; font-family: "Noto Sans", sans-serif; letter-spacing: -0.025em; max-width: 43rem; text-wrap: balance; }
			.post-hero--signal { --post-hero-accent: #1A33F6; }
			.post-hero--editorial { --post-hero-accent: #1A33F6; }
			.post-hero--broadcast { --post-hero-accent: #1A33F6; }
			.post-hero--signal .article-hero { border-color: rgba(26,51,246,0.28); }
			.post-hero--editorial .article-hero { border-color: rgba(26,51,246,0.24); }
			.post-hero--broadcast .article-hero { border-color: rgba(26,51,246,0.24); }
			.post-hero--video-card .post-hero-grid { grid-template-columns: minmax(24rem, 1.16fr) minmax(0, 0.84fr); align-items: center; }
			.post-hero--video-card .intro-section h1.article-title { font-size: clamp(2.3rem, 3.65vw, 3.75rem); line-height: 1.02; max-width: 14ch; }
			.post-hero--video-card .intro-section .article-excerpt { font-size: clamp(1.05rem, 1.35vw, 1.28rem); line-height: 1.48; max-width: 37rem; }
			.post-hero-feature { display: grid; gap: clamp(1.8rem, 4vw, 3.25rem); }
			.post-hero-feature--split { grid-template-columns: minmax(10rem, 14.5rem) minmax(0, 1fr); gap: clamp(2rem, 4.2vw, 4rem); align-items: start; }
			.post-hero-feature__main { min-width: 0; display: grid; gap: clamp(1.7rem, 3.8vw, 3rem); }
			.post-hero-feature--split .post-hero-feature__main { display: contents; }
			.post-hero-feature__intro { max-width: min(920px, 100%); }
			.post-hero-feature__intro h1.article-title { max-width: 15ch; font-size: clamp(2.65rem, 5.6vw, 5.8rem); line-height: 0.94; letter-spacing: -0.058em; }
			.post-hero-feature__intro .article-excerpt { max-width: 760px; font-size: clamp(1rem, 1.35vw, 1.28rem); line-height: 1.44; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
			.post-hero-feature--split .post-hero-feature__intro { grid-column: 2; max-width: min(940px, 100%); }
			.post-hero-feature--split .post-hero-feature__intro h1.article-title { max-width: 15.5ch; font-size: clamp(2.7rem, 5.25vw, 5.45rem); line-height: 0.94; }
			.post-hero-feature--split .post-hero-feature__intro .article-excerpt { max-width: 720px; }
			.episode-rail { grid-column: 1; grid-row: 1; min-height: clamp(11rem, 18vw, 17rem); padding-right: clamp(1.25rem, 2.8vw, 2.4rem); border-right: 1px solid rgba(251,248,239,0.16); color: var(--post-hero-muted); display: flex; flex-direction: column; gap: 1.25rem; }
			.episode-rail__eyebrow, .episode-rail__meta, .episode-rail__series span { font-family: "DM Sans", sans-serif; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
			.episode-rail__eyebrow { display: block; margin-bottom: 0.55rem; opacity: 0.72; }
			.episode-rail__author { display: inline-flex; align-items: center; gap: 0.65rem; color: var(--post-hero-ink); text-decoration: none; border: 0; font-family: "Noto Sans", sans-serif; font-weight: 800; font-size: 0.92rem; line-height: 1.15; }
			.episode-rail__author img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; filter: grayscale(100%); box-shadow: 0 0 0 1px rgba(251,248,239,0.32); }
			.episode-rail__meta { display: grid; gap: 0.35rem; line-height: 1.45; opacity: 0.86; }
			.episode-rail__actions { display: flex; gap: 0.75rem; align-items: center; }
			.episode-action { width: 2.55rem; height: 2.55rem; padding: 0; border-radius: 50%; border: 1px solid rgba(251,248,239,0.28); background: rgba(255,255,255,0.035); color: var(--post-hero-ink); display: inline-flex; align-items: center; justify-content: center; cursor: pointer; font: inherit; transition: transform 160ms ease, background 160ms ease, border-color 160ms ease, color 160ms ease; }
			.episode-action svg { width: 1.05rem; height: 1.05rem; display: block; }
			.episode-action:hover, .episode-action[data-copied="true"] { transform: translateY(-1px); background: #1A33F6; border-color: #1A33F6; color: #fff; }
			.episode-rail__series { margin-top: auto; display: grid; gap: 0.28rem; color: var(--post-hero-muted); text-decoration: none; border: 1px solid rgba(251,248,239,0.14); border-radius: 16px; padding: 0.9rem 1rem; background: rgba(255,255,255,0.035); transition: background 160ms ease, border-color 160ms ease, transform 160ms ease; }
			.episode-rail__series strong { color: var(--post-hero-ink); font-family: "Gilroy-ExtraBold", sans-serif; font-size: 1.03rem; letter-spacing: -0.015em; line-height: 1.15; }
			.episode-rail__series:hover { background: rgba(255,255,255,0.075); border-color: rgba(251,248,239,0.28); transform: translateY(-1px); }
			.article-hero--feature { width: min(100%, 1040px); margin: 0 auto; border-color: rgba(251,248,239,0.16); box-shadow: 0 30px 95px rgba(0,0,0,0.38); }
			.post-hero-feature--split .article-hero--feature { grid-column: 1 / -1; width: 100%; margin: 0; }
			.post-hero-feature--split .article-hero--feature::before { inset: -4.75%; filter: blur(38px) saturate(1.72) contrast(1.04); opacity: 0.56; }
			.post-hero--video-feature { padding-bottom: clamp(4.5rem, 7vw, 7rem); background: radial-gradient(circle at 22% 64%, rgba(255,255,255,0.08), transparent 28rem), linear-gradient(135deg, rgba(255,255,255,0.08), transparent 46%), var(--post-hero-bg); }
			.post-hero--video-feature .article-hero::before { inset: -3.25%; filter: blur(30px) saturate(1.65) contrast(1.04); opacity: 0.5; transform: scale(1); }
			.post-hero--long-title .post-hero-grid { grid-template-columns: minmax(20rem, 0.96fr) minmax(0, 1.04fr); align-items: center; }
			.post-hero--long-title .intro-section h1.article-title { font-size: clamp(2.25rem, 3.75vw, 3.65rem); line-height: 1.03; letter-spacing: -0.042em; max-width: 14.5ch; }
			.post-hero--long-title .intro-section .article-excerpt { font-size: clamp(1.05rem, 1.35vw, 1.32rem); line-height: 1.44; max-width: 42rem; }
			.post-hero + section { margin-top: -1px; border-top: 0; }
			.post-hero + section .content-layout { padding-top: clamp(5rem, 7vw, 7rem); }
			.post-hero + section .article { padding-top: 0; }
			.post-hero + section .toc { padding-top: 0; }
			@media (max-width: 991.98px) {
				.post-hero--video-card .post-hero-grid { grid-template-columns: 1fr; }
				.post-hero-feature__intro h1.article-title { font-size: clamp(2.4rem, 9vw, 4rem); max-width: none; }
				.post-hero-feature--split { grid-template-columns: 1fr; gap: 1.65rem; }
				.post-hero-feature__main { display: grid; gap: 1.65rem; }
				.episode-rail { grid-column: auto; grid-row: auto; min-height: 0; padding: 0 0 1.25rem; border-right: 0; border-bottom: 1px solid rgba(251,248,239,0.14); display: grid; grid-template-columns: 1fr auto; align-items: end; }
				.episode-rail__series { margin-top: 0; grid-column: 1 / -1; }
				.post-hero-feature--split .post-hero-feature__main { display: grid; }
				.post-hero-feature--split .post-hero-feature__intro, .post-hero-feature--split .article-hero--feature { grid-column: auto; }
			}
			@media (max-width: 767.98px) {
				.post-hero-feature { gap: 1.65rem; }
				.article-hero--video { border-radius: 18px; }
			}
			@media (prefers-color-scheme: dark) {
				body.has-post-hero main { background: #101012; }
				body.has-post-hero .post-hero + section { background: radial-gradient(circle at 18% 0, rgba(255,255,255,0.026), transparent 26rem), linear-gradient(180deg, #0f0f11 0, #101012 5.5rem); }
				body.has-post-hero .article-content h1,
				body.has-post-hero .article-content h2,
				body.has-post-hero .article-content h3 { color: #f4f4f4 !important; }
				body.has-post-hero .article-content p,
				body.has-post-hero .article-content ul,
				body.has-post-hero .article-content ol,
				body.has-post-hero .article-content li { color: rgba(244,244,244,0.74); }
			}
		</style>
		{
			jsonLd.map((schema) => (
				<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
			))
		}
		<script is:inline>
			// Apply theme immediately to prevent flash
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body class:list={[type === "article" && "has-post-hero"]}>
		<EmDashBodyStart page={pageCtx} />
		<header class:list={["site-header", type === "article" && "on-dark"]} id="site-header">
			<div class="header-inner">
				<a href="/" class="header-logo">
					<img
						src="/brand/maldito-genio-logo.svg"
						alt="Maldito Genio"
						width="362"
						height="161"
					/>
				</a>
				<nav class="header-nav">
					{
						headerMenuItems.slice(0, -1).map((item) => (
							<a href={item.url} target={item.target}>
								{item.label}
							</a>
						))
					}
					{
						headerMenuItems.length && (
							<a
								href={headerMenuItems[headerMenuItems.length - 1].url}
								target={headerMenuItems[headerMenuItems.length - 1].target}
								class="btn-header"
							>
								{headerMenuItems[headerMenuItems.length - 1].label}
							</a>
						)
					}
				</nav>
				<button class="hamburger" id="hamburger" aria-label="Menú" aria-expanded="false" aria-controls="mobile-menu">
					<span></span><span></span><span></span>
				</button>
			</div>
		</header>
		<nav class="mobile-menu" id="mobile-menu">
			{
				headerMenuItems.map((item) => (
					<a href={item.url} target={item.target}>
						{item.label}
					</a>
				))
			}
		</nav>

		<main>
			<slot />
		</main>

		<footer class="footer">
			<div class="footer-blob-tr"></div>
			<div class="footer-blob-bl"></div>
			<div class="c">
				<div class="footer-contact">
					<h3>Hablemos</h3>
					<div class="footer-contact-info">
						<p><a href="mailto:hello@andresospina.co">hello@andresospina.co</a></p>
						<p><a href="https://andresospina.co">andresospina.co</a></p>
					</div>
				</div>
				<div class="footer-copy">© {new Date().getFullYear()} Andrés Ospina · MalditoGenio!</div>
			</div>
		</footer>

		<script is:inline>
			// Same headbar behavior used by the Astro event landings:
			// the pill adapts when its midpoint overlaps a dark section.
			const header = document.getElementById("site-header");
			const hamburger = document.getElementById("hamburger");
			const mobileMenu = document.getElementById("mobile-menu");
			const darkSectionSelector = [
				'[data-headbar-theme="dark"]',
				".headbar-dark-section",
				".communities-dark",
				".other-cities-dark",
			].join(", ");

			function updateHeader() {
				if (!header) return;
				header.classList.toggle("scrolled", window.scrollY > 60);

				const hRect = header.getBoundingClientRect();
				const hMid = hRect.top + hRect.height / 2;
				let onDark = false;

				document.querySelectorAll(darkSectionSelector).forEach((section) => {
					const sRect = section.getBoundingClientRect();
					if (hMid >= sRect.top && hMid <= sRect.bottom) onDark = true;
				});

				header.classList.toggle("on-dark", onDark);
			}

			updateHeader();
			window.addEventListener("scroll", updateHeader, { passive: true });
			window.addEventListener("resize", updateHeader);
			hamburger?.addEventListener("click", () => {
				hamburger.classList.toggle("open");
				mobileMenu?.classList.toggle("open");
				hamburger.setAttribute("aria-expanded", hamburger.classList.contains("open") ? "true" : "false");
			});
			mobileMenu?.querySelectorAll("a").forEach((a) => {
				a.addEventListener("click", () => {
					hamburger?.classList.remove("open");
					mobileMenu?.classList.remove("open");
					hamburger?.setAttribute("aria-expanded", "false");
				});
			});

		</script>
		<Melon />
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
