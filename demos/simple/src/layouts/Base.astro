---
import { getMenu, getEmDashCollection } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import { Font } from "astro:assets";
import "../styles/theme.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
	/** JSON-LD schema blocks to inject in <head> */
	jsonLd?: Record<string, unknown>[];
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	jsonLd = [],
} = Astro.props;
const siteTitle = "Andrés Ospina";
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

// Fetch primary menu defined in seed
const menu = await getMenu("primary");

// Fetch pages for footer
const { entries: pages } = await getEmDashCollection("pages");

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#1A33F6" />
		<link rel="icon" type="image/png" href="/brand/favicon.png" sizes="32x32" />
		<link rel="shortcut icon" type="image/png" href="/brand/favicon.png" />
		<link rel="apple-touch-icon" href="/brand/favicon.png" />
		<link rel="preload" href="/fonts/gilroy-extrabold.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/noto-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
		<Font cssVariable="--font-mono" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<style is:inline>
			/* Critical CSS — above-the-fold, inlined for first paint */
			@font-face { font-family: "Gilroy-ExtraBold"; src: url("/fonts/gilroy-extrabold.woff2") format("woff2"); font-display: swap; }
			html { scroll-behavior: smooth; scroll-padding-top: 5rem; }
			html, body { margin: 0; padding: 0; }
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: "Noto Sans", -apple-system, BlinkMacSystemFont, sans-serif;
				font-size: 17px;
				line-height: 1.6;
				letter-spacing: -0.01em;
				color: #1d1d1f;
				background: #fff;
				-webkit-font-smoothing: antialiased;
				overflow-x: hidden;
			}
			a { color: #1A33F6; text-decoration: none; }
			img { max-width: 100%; height: auto; display: block; }
			.c { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; }
			main { padding-top: 6rem; min-height: calc(100vh - 400px); }
			/* Header pill — critical for first paint */
			.site-header {
				position: fixed; top: 1rem; left: 50%; transform: translateX(-50%);
				z-index: 100; width: calc(100% - 2rem); max-width: 1100px;
				padding: 0.75rem 1.5rem; border-radius: 999px;
				background: rgba(255,255,255,0.55);
				backdrop-filter: blur(24px) saturate(180%);
				-webkit-backdrop-filter: blur(24px) saturate(180%);
				border: 1px solid rgba(255,255,255,0.35);
				box-shadow: 0 4px 24px rgba(0,0,0,0.06);
			}
			.header-inner { display: flex; align-items: center; justify-content: space-between; }
			.header-logo { display: inline-flex; align-items: center; text-decoration: none; }
			.header-logo img { height: 1.8rem; width: auto; min-width: 80px; max-width: 140px; object-fit: contain; filter: brightness(0); }
			.header-nav { display: flex; align-items: center; gap: 1.6rem; }
			.header-nav a { font-size: 0.82rem; color: rgba(0,0,0,0.45); font-family: "Gilroy-ExtraBold", sans-serif; font-weight: 700; white-space: nowrap; }
			.header-nav .btn-header { background: #1A33F6; color: #fff !important; padding: 0.55rem 1.15rem; border-radius: 999px; font-size: 0.78rem; }
			/* Hero + intro (above the fold on post pages) */
			.hero { padding: 1.5rem 0 0.5rem; }
			.breadcrumb { font-size: 0.82rem; color: #555; margin-bottom: 0.5rem; font-family: "DM Sans", sans-serif; }
			.breadcrumb a { color: #1A33F6; font-weight: 600; }
			.intro-section { max-width: 820px; padding: 0.75rem 0 0; }
			.intro-section h1.article-title {
				font-family: "Gilroy-ExtraBold", sans-serif;
				font-size: 2.75rem;
				color: #1d1d1f;
				letter-spacing: -0.04em;
				line-height: 1.1;
				margin: 0 0 0.6rem;
				font-weight: 700;
			}
			.intro-section .article-meta {
				font-family: "DM Sans", sans-serif;
				font-size: 0.9rem;
				color: #86868b;
				margin: 0;
				display: flex;
				gap: 0.6rem;
				align-items: center;
				flex-wrap: wrap;
			}
			.intro-section .article-meta .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: #86868b; display: inline-block; }
			.intro-section .article-meta-author { display: inline-flex; align-items: center; gap: 0.55rem; text-decoration: none; border: none; }
			.intro-section .article-meta-avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; flex-shrink: 0; filter: grayscale(100%); }
			.intro-section .article-meta-byline { color: #1d1d1f; font-weight: 600; font-family: "Noto Sans", sans-serif; }
			.article-hero { width: 100%; border-radius: 12px; overflow: hidden; margin-top: 1.5rem; }
			.article-hero img { width: 100%; height: auto; border-radius: 12px; margin: 0; }
		</style>
		{
			jsonLd.map((schema) => (
				<script type="application/ld+json" set:html={JSON.stringify(schema)} />
			))
		}
		<script is:inline>
			// Apply theme immediately to prevent flash
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class="site-header" id="site-header">
			<div class="header-inner">
				<a href="/" class="header-logo">
					<img
						src="/brand/maldito-genio-logo.svg"
						alt="Maldito Genio"
						width="362"
						height="161"
					/>
				</a>
				<nav class="header-nav">
					{
						menu?.items.slice(0, -1).map((item) => (
							<a href={item.url} target={item.target}>
								{item.label}
							</a>
						))
					}
					<div class="header-search" id="header-search">
						<button
							type="button"
							class="header-search-toggle"
							id="header-search-toggle"
							aria-label="Buscar"
							aria-expanded="false"
						>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="11" cy="11" r="8"></circle>
								<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
							</svg>
						</button>
						<form method="get" action="/search" class="header-search-field" role="search">
							<input
								type="search"
								name="q"
								placeholder="Buscar artículos..."
								class="header-search-input"
								autocomplete="off"
							/>
						</form>
					</div>
					{
						menu?.items.length && (
							<a
								href={menu.items[menu.items.length - 1].url}
								target={menu.items[menu.items.length - 1].target}
								class="btn-header"
							>
								{menu.items[menu.items.length - 1].label}
							</a>
						)
					}
				</nav>
				<button class="hamburger" id="hamburger" aria-label="Menú">
					<span></span><span></span><span></span>
				</button>
			</div>
		</header>
		<nav class="mobile-menu" id="mobile-menu">
			{
				menu?.items.map((item) => (
					<a href={item.url} target={item.target}>
						{item.label}
					</a>
				))
			}
		</nav>

		<main>
			<slot />
		</main>

		<footer class="footer">
			<div class="footer-blob-tr"></div>
			<div class="footer-blob-bl"></div>
			<div class="c">
				<div class="footer-contact">
					<h3>Hablemos</h3>
					<div class="footer-contact-info">
						<p><a href="mailto:hello@andresospina.co">hello@andresospina.co</a></p>
						<p><a href="https://andresospina.co">andresospina.co</a></p>
					</div>
				</div>
				<div class="footer-copy">© {new Date().getFullYear()} Andrés Ospina · MalditoGenio!</div>
			</div>
		</footer>

		<script>
			// Header scroll + hamburger (from /sobre-mi/)
			const header = document.getElementById("site-header");
			const hamburger = document.getElementById("hamburger");
			const mobileMenu = document.getElementById("mobile-menu");
			window.addEventListener("scroll", () => {
				header?.classList.toggle("scrolled", window.scrollY > 10);
			});
			hamburger?.addEventListener("click", () => {
				hamburger.classList.toggle("open");
				mobileMenu?.classList.toggle("open");
			});
			mobileMenu?.querySelectorAll("a").forEach((a) => {
				a.addEventListener("click", () => {
					hamburger?.classList.remove("open");
					mobileMenu?.classList.remove("open");
				});
			});

			// Header search toggle — expand input on icon click
			const searchBox = document.getElementById("header-search");
			const searchToggle = document.getElementById("header-search-toggle");
			searchToggle?.addEventListener("click", (e) => {
				e.stopPropagation();
				const isOpen = searchBox?.classList.toggle("open");
				searchToggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
				if (isOpen) {
					const input = searchBox?.querySelector(
						".header-search-input"
					) as HTMLInputElement | null;
					setTimeout(() => input?.focus(), 50);
				}
			});
			document.addEventListener("click", (e) => {
				if (!searchBox?.classList.contains("open")) return;
				if (!searchBox.contains(e.target as Node)) {
					searchBox.classList.remove("open");
					searchToggle?.setAttribute("aria-expanded", "false");
				}
			});
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape" && searchBox?.classList.contains("open")) {
					searchBox.classList.remove("open");
					searchToggle?.setAttribute("aria-expanded", "false");
				}
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					searchToggle?.click();
				}
			});
		</script>



		<script>
			// ⌘K / Ctrl+K to focus search
			document.addEventListener("keydown", (e) => {
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					const searchInput = document.querySelector(
						".site-search-input"
					) as HTMLInputElement;
					if (searchInput) {
						searchInput.focus();
					}
				}
			});
		</script>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
