---
import { getEmDashCollection, getEntryTerms } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { getReadingTime } from "../utils/reading-time";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

// 7 latest posts for the featured grid (same count as production)
const featuredPosts = sortedPosts.slice(0, 7);
const featuredWithTags = await Promise.all(
	featuredPosts.map(async (p) => {
		const tags = await getEntryTerms("posts", p.data.id, "tag");
		return { post: p, tags };
	})
);

const formatDate = (d: Date) =>
	d.toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });

// Homepage structured data (Person + WebSite + Organization)
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"@id": "https://andresospina.co/#person",
	name: "Andrés Ospina",
	alternateName: "MalditoGenio",
	jobTitle: "Head of Growth",
	description:
		"Growth marketer en Colombia con 15+ años de experiencia. Especializado en sistemas de adquisición con IA para SaaS y startups LATAM.",
	url: Astro.url.origin,
	image: "/brand/andres-hero.jpg",
	worksFor: {
		"@type": "Organization",
		name: "Robot.com",
		url: "https://robot.com",
	},
	sameAs: [
		"https://www.linkedin.com/in/andresospina/",
		"https://x.com/malditogenio",
		"https://andresospina.co",
		"https://www.instagram.com/maldito_genio/",
	],
	knowsAbout: [
		"Growth Marketing",
		"Artificial Intelligence in Marketing",
		"B2B SaaS Acquisition",
		"Marketing Automation",
		"SEO",
		"Google Ads",
		"Meta Ads",
		"Lead Generation",
		"Conversion Rate Optimization",
	],
	address: {
		"@type": "PostalAddress",
		addressLocality: "Bogotá",
		addressCountry: "CO",
	},
	knowsLanguage: ["es", "en"],
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${Astro.url.origin}/#website`,
	url: Astro.url.origin,
	name: "Andrés Ospina — MalditoGenio",
	description:
		"Growth marketing, IA aplicada y sistemas de adquisición. Lo que funciona, lo que no, y los números reales.",
	publisher: { "@id": "https://andresospina.co/#person" },
	inLanguage: "es-CO",
	potentialAction: {
		"@type": "SearchAction",
		target: `${Astro.url.origin}/search?q={search_term_string}`,
		"query-input": "required name=search_term_string",
	},
};

// Client logos — same as production marquee
const clientLogos = [
	{ name: "jbalvin", src: "https://andresospina.co/wp-content/uploads/2025/07/jbalvin.png" },
	{ name: "kayak", src: "https://andresospina.co/wp-content/uploads/2025/07/kayak.png" },
	{ name: "pym", src: "https://andresospina.co/wp-content/uploads/2025/07/pym.png" },
	{ name: "auteco", src: "https://andresospina.co/wp-content/uploads/2025/07/auteco.png" },
	{ name: "rdstation", src: "https://andresospina.co/wp-content/uploads/2025/07/rdstation.png" },
	{ name: "codegpt", src: "https://andresospina.co/wp-content/uploads/2025/07/codegpt.png" },
	{ name: "platzi", src: "https://andresospina.co/wp-content/uploads/2025/07/platzi.png" },
];

// Topics list ("Sobre lo que escribo" — from production)
const writingTopics = [
	"Head of Growth y Head of Marketing",
	"Consultor de inbound marketing",
	"Consultor de inteligencia artificial para marketing",
	"Marketing de automatización",
];
---

<Base
	title="Andrés Ospina — Growth Marketing & IA | MalditoGenio"
	description="Estratega de growth marketing e inteligencia artificial. Sistemas que aceleran ventas con datos, automatización y agentes de IA. Ex-Platzi, RD Station, CodeGPT."
	jsonLd={[personSchema, websiteSchema]}
>
	<!-- HERO — profile + hola + huge two-tone title + static logo strip -->
	<section class="home-wp-hero">
		<div class="c">
			<div class="home-wp-hero-intro">
				<img
					src="/brand/andres-hero.jpg"
					alt="Andrés Ospina"
					class="home-wp-hero-avatar"
					width="160"
					height="160"
					loading="eager"
				/>
				<div class="home-wp-hero-greeting">
					<p class="home-wp-hello">Hola, soy</p>
					<p class="home-wp-name-small">Andrés Ospina</p>
				</div>
			</div>
			<h2 class="home-wp-title">
				Growth <span class="home-wp-title-muted">Marketing</span> Strategist
			</h2>
		</div>

		<!-- Client logos marquee (scrolling) — full width -->
		<div class="home-wp-logos">
			<div class="home-wp-logos-track">
				{
					[...clientLogos, ...clientLogos, ...clientLogos].map((logo) => (
						<img src={logo.src} alt={logo.name} class="home-wp-logo" loading="lazy" />
					))
				}
			</div>
		</div>
	</section>

	<!-- "ESTO ES LO QUE HAGO" — production copy -->
	<section class="home-services">
		<div class="c">
			<h2 class="home-wp-section-title">
				Esto es lo<br />que hago
			</h2>
			<div class="home-services-copy">
				<p>
					Tengo un trabajo simple: <strong>diseñar y ejecutar las máquinas de crecimiento</strong> con las que tu equipo de ventas siempre soñó. Conecto los puntos entre producto, marketing y datos para que dejes de depender de tácticas aisladas y empieces a ver resultados predecibles.
				</p>
				<p>
					Mi método ha sido probado en el campo de batalla con empresas como <strong>RD Station, Kayak y J Balvin</strong>. En CodeGPT, mi sistema de IA generó un crecimiento explosivo. En Platzi, reduje el CPL en un 56%. No contratarme es, literalmente, dejar de ganar mucho dinero.
				</p>
			</div>
		</div>
	</section>

	<!-- FEATURED POSTS -->
	<section class="home-wp-posts">
		<div class="c">
			<div class="home-wp-posts-head">
				<h2 class="home-wp-posts-title">Lo último<br />del blog</h2>
				<p class="home-wp-posts-lede">
					Growth marketing, IA aplicada y sistemas de adquisición. Lo que funciona, lo que no, y los números reales.
				</p>
			</div>
			<div class="home-wp-grid">
				{featuredWithTags.map(({ post, tags }, i) => (
					<a href={`/${post.id}`} class={`home-wp-card ${i === 0 ? "home-wp-card-big" : ""}`}>
						<div class="home-wp-card-media">
							{post.data.featured_image && (
								<Image image={post.data.featured_image} />
							)}
						</div>
						<div class="home-wp-card-body">
							{tags.length > 0 && <div class="home-wp-card-tag">{tags[0].label}</div>}
							<h3 class="home-wp-card-title">{post.data.title}</h3>
							{i === 0 && post.data.excerpt && (
								<p class="home-wp-card-excerpt">{post.data.excerpt}</p>
							)}
							<div class="home-wp-card-meta">
								{post.data.publishedAt && <time>{formatDate(post.data.publishedAt)}</time>}
								<span class="meta-dot" />
								<span>{getReadingTime(post.data.content)} min</span>
							</div>
						</div>
					</a>
				))}
			</div>
			<div class="home-wp-cta">
				<a href="/blog" class="home-cta home-cta-primary">Ver todos los artículos</a>
			</div>
		</div>
	</section>

	<!-- SOBRE LO QUE ESCRIBO -->
	<section class="home-topics">
		<div class="c">
			<p class="home-topics-eyebrow">Sobre lo que escribo</p>
			<h2 class="home-topics-title">
				Los temas que<br />obsesionan a mi teclado
			</h2>
			<ul class="home-topics-list">
				{writingTopics.map((t) => (
					<li class="home-topic-item">{t}</li>
				))}
			</ul>
		</div>
	</section>
</Base>
