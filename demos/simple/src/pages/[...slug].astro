	<script>
		function revealRelatedCard(el: Element) {
			el.classList.add("is-visible");
		}

		// Build a quiet editorial TOC from H2s only. H3s made the rail too noisy.
		function buildToc() {
			const content = document.querySelector(".article-content");
			const tocContainer = document.getElementById("toc-content");
			const tocEl = document.getElementById("article-toc");
			if (!content || !tocContainer || !tocEl) return;

			const headings = [...content.querySelectorAll("h2")] as HTMLElement[];
			if (headings.length === 0) {
				tocEl.style.display = "none";
				return;
			}

			const list = document.createElement("ul");
			list.className = "toc-list";

			type LinkRef = {
				heading: HTMLElement;
				link: HTMLAnchorElement;
				li: HTMLLIElement;
			};
			const links: LinkRef[] = [];
			headings.forEach((heading, index) => {
				if (!heading.id) heading.id = `heading-${index}`;

				const li = document.createElement("li");
				li.className = "toc-item toc-item--h2";
				li.dataset.headingId = heading.id;

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = "toc-link toc-link--h2";
				link.textContent = heading.textContent;
				li.appendChild(link);

				list.appendChild(li);
				links.push({ heading, link, li });
			});

			tocContainer.appendChild(list);

			function setActive(activeId: string | null) {
				links.forEach((l) => l.link.classList.remove("active"));
				list.querySelectorAll(".toc-item.is-open").forEach((el) =>
					el.classList.remove("is-open"),
				);
				if (!activeId) return;
				const info = links.find((l) => l.heading.id === activeId);
				if (!info) return;
				info.link.classList.add("active");
				info.li.classList.add("is-open");
			}

			// Map each content element to its closest preceding H2 id
			const contentElements = new Map<Element, string>();
			let cursor: string | null = null;
			[...content.children].forEach((el) => {
				if (el.id && el.tagName === "H2") {
					cursor = el.id;
				}
				if (cursor) contentElements.set(el, cursor);
			});

			const visible = new Set<Element>();
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) visible.add(entry.target);
						else visible.delete(entry.target);
					});
					const firstVisible = [...contentElements.entries()].find(
						([el]) => visible.has(el),
					);
					setActive(firstVisible?.[1] ?? null);
				},
				{
					rootMargin: `-${getComputedStyle(document.documentElement).scrollPaddingTop || "80px"} 0px -80% 0px`,
				},
			);

			contentElements.forEach((_, el) => observer.observe(el));
		}

		buildToc();

		// Scroll-triggered reveal for related post cards only (honors prefers-reduced-motion).
		// InlineAd cards show by default — scroll-reveal caused gaps on hash landings and quick scroll.
		(function () {
			const prefersReduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
			const cards = document.querySelectorAll(".related-post-card");

			if (prefersReduced) {
				cards.forEach(revealRelatedCard);
				return;
			}

			if (cards.length) {
				const cardObs = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								const index = [...cards].indexOf(entry.target as Element);
								(entry.target as HTMLElement).style.transition =
									`opacity 0.55s cubic-bezier(0.25, 1, 0.5, 1) ${index * 90}ms, transform 0.55s cubic-bezier(0.25, 1, 0.5, 1) ${index * 90}ms, box-shadow 0.2s, border-color 0.2s`;
								revealRelatedCard(entry.target);
								cardObs.unobserve(entry.target);
							}
						});
					},
					{ rootMargin: "0px 0px -10% 0px" }
				);
				cards.forEach((c) => cardObs.observe(c));
			}
			})();

			// Rail play action: keep people in the hero video instead of sending them to YouTube.
			(function () {
				const playButton = document.querySelector("[data-play-hero-video]");
				const heroVideo = document.getElementById("hero-video");
				const player = document.querySelector("[data-hero-video-player]") as
					| HTMLIFrameElement
					| HTMLVideoElement
					| null;
				if (!playButton || !heroVideo || !player) return;

				playButton.addEventListener("click", () => {
					heroVideo.scrollIntoView({ behavior: "smooth", block: "center" });

					if (player instanceof HTMLVideoElement) {
						void player.play();
						return;
					}

					try {
						const url = new URL(player.src);
						url.searchParams.set("autoplay", "1");
						url.searchParams.set("rel", "0");
						player.src = url.toString();
						player.focus();
					} catch {
						player.focus();
					}
				});
			})();

			// Episode share action: native share when available, clipboard fallback otherwise.
			(function () {
				const buttons = document.querySelectorAll("[data-copy-share]");
				buttons.forEach((button) => {
					button.addEventListener("click", async () => {
						const el = button as HTMLButtonElement;
						const url = el.dataset.shareUrl || location.href;
						const title = document.title;
						try {
							if (navigator.share) {
								await navigator.share({ title, url });
							} else {
								await navigator.clipboard.writeText(url);
							}
							el.dataset.copied = "true";
							setTimeout(() => {
								delete el.dataset.copied;
							}, 1600);
						} catch {
							delete el.dataset.copied;
						}
					});
				});
			})();

			// Reading progress bar
			(function () {
			const bar = document.getElementById("read-progress") as HTMLElement | null;
			const article = document.querySelector(".article-content") as HTMLElement | null;
			if (!bar || !article) return;
			let raf = 0;
			function update() {
				const rect = article!.getBoundingClientRect();
				const total = rect.height - window.innerHeight + 240;
				const scrolled = -rect.top + 140;
				const pct = Math.max(0, Math.min(100, (scrolled / total) * 100));
				bar!.style.width = pct + "%";
				raf = 0;
			}
			addEventListener(
				"scroll",
				() => {
					if (!raf) raf = requestAnimationFrame(update);
				},
				{ passive: true }
			);
			update();
		})();
	</script>
