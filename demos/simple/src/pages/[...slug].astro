---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
	decodeSlug,
} from "emdash";
import type { PortableTextBlock } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import InlineAd, { type InlineAdOverride, type InlineAdVariant } from "../components/InlineAd.astro";
import { extractText, getReadingTime } from "../utils/reading-time";

const TRAILING_PUNCTUATION_REGEX = /[,\s;:]+$/;
const WHITESPACE_REGEX = /\s+/g;
const INLINE_TOC_TITLES = new Set([
	"table of contents",
	"tabla de contenido",
	"tabla de contenidos",
	"contenido de esta guia",
	"contenido de esta guía",
	"indice",
	"índice",
]);
const INLINE_TOC_HTML_MARKERS = [
	"rank-math-toc",
	'id="tabla-de-contenido"',
	'id="table-of-contents"',
	'class="wp-block-rank-math-toc',
];
const AD_VARIANTS = new Set<InlineAdVariant>([
	"ia",
	"growth",
	"agencias",
	"conferencias",
	"catchall",
	"newsletter",
	"curso",
]);
const WWW_PREFIX_REGEX = /^www\./;
const DIRECT_VIDEO_URL_REGEX = /\.(mp4|webm|mov)(\?.*)?$/i;
const VIMEO_NUMERIC_PATH_PART_REGEX = /^\d+$/;
const OBJECT_POSITION_REGEX =
	/^(?:-?\d+(?:\.\d+)?%?|left|center|right|top|bottom)(?:\s+(?:-?\d+(?:\.\d+)?%?|left|center|right|top|bottom))?$/i;

function pickAdVariant(signals: string[]): InlineAdVariant {
	const blob = signals.join(" ").toLowerCase();
	const hasAny = (keys: string[]) => keys.some((k) => blob.includes(k));
	if (
		hasAny([
			"ai",
			" ia ",
			"inteligencia artificial",
			"inteligencia-artificial",
			"automatizacion",
			"claude",
			"chatgpt",
			"llm",
			"agentes-ia",
			"gpt",
			"openai",
			"gemini",
			"prompt",
		])
	)
		return "ia";
	if (hasAny(["growth-marketing", "performance-marketing", "ppc", "abm", "pipeline", "growth", "funnel"]))
		return "growth";
	if (hasAny(["inbound-marketing", "inbound", "agencias", "agencia"]))
		return "agencias";
	if (hasAny(["conferencias", "conferencia", "evento", "speaker", "keynote", "charla"]))
		return "conferencias";
	return "catchall";
}

function getBlockTexts(blocks: unknown[]): string[] {
	return blocks
		.filter((block): block is { _type: string; style?: string; children?: unknown[] } =>
			typeof block === "object" && block !== null && (block as { _type?: unknown })._type === "block"
		)
		.filter((block) => !block.style || block.style === "normal")
		.map((block) =>
			(block.children ?? [])
				.filter((child): child is { _type: string; text: string } =>
					typeof child === "object" &&
					child !== null &&
					(child as { _type?: unknown })._type === "span" &&
					typeof (child as { text?: unknown }).text === "string"
				)
				.map((child) => child.text)
				.join("")
				.trim()
		)
		.filter(Boolean);
}

function getPortableTextBlockText(block: unknown): string {
	if (
		typeof block !== "object" ||
		block === null ||
		(block as { _type?: unknown })._type !== "block" ||
		!Array.isArray((block as { children?: unknown }).children)
	) {
		return "";
	}
	return ((block as { children: unknown[] }).children)
		.filter((child): child is { text: string } =>
			typeof child === "object" &&
			child !== null &&
			typeof (child as { text?: unknown }).text === "string"
		)
		.map((child) => child.text)
		.join("")
		.trim();
}

function getPortableTextBlockStyle(block: unknown): string {
	if (typeof block !== "object" || block === null || (block as { _type?: unknown })._type !== "block") {
		return "";
	}
	const style = (block as { style?: unknown }).style;
	return typeof style === "string" ? style.toLowerCase() : "";
}

function isPortableTextHeading(block: unknown): boolean {
	return ["h1", "h2", "h3", "h4"].includes(getPortableTextBlockStyle(block));
}

function normalizeTocTitle(value: string): string {
	return value.trim().toLowerCase().replace(WHITESPACE_REGEX, " ").replace(/:$/, "");
}

function isInlineTocBlock(block: unknown): boolean {
	if (typeof block !== "object" || block === null) return false;
	if ((block as { _type?: unknown })._type === "htmlBlock") {
		const html = (block as { html?: unknown }).html;
		return typeof html === "string" && INLINE_TOC_HTML_MARKERS.some((marker) => html.includes(marker));
	}
	const text = normalizeTocTitle(getPortableTextBlockText(block));
	if (!text) return false;
	return INLINE_TOC_TITLES.has(text) || (isPortableTextHeading(block) && text === "contenido");
}

function stripInlineTocBlocks(blocks: PortableTextBlock[]): PortableTextBlock[] {
	const cleaned: PortableTextBlock[] = [];
	for (let index = 0; index < blocks.length; index += 1) {
		const block = blocks[index];
		if (!isInlineTocBlock(block)) {
			cleaned.push(block);
			continue;
		}

		if (isPortableTextHeading(block)) {
			while (index + 1 < blocks.length && !isPortableTextHeading(blocks[index + 1])) {
				index += 1;
			}
		}
	}
	return cleaned;
}

function truncateSentence(text: string, maxLength: number): string {
	if (text.length <= maxLength) return text;
	const sliced = text.slice(0, maxLength).trim();
	const lastStop = Math.max(sliced.lastIndexOf("."), sliced.lastIndexOf("?"), sliced.lastIndexOf("!"));
	if (lastStop > maxLength * 0.55) return sliced.slice(0, lastStop + 1);
	return `${sliced.replace(TRAILING_PUNCTUATION_REGEX, "")}...`;
}

function cleanDeck(value: unknown): string | null {
	if (typeof value !== "string") return null;
	const normalized = value.trim().replace(WHITESPACE_REGEX, " ");
	return normalized || null;
}

function getAdText(value: unknown): string | undefined {
	return cleanDeck(value) ?? undefined;
}

function getAdVariant(value: unknown, fallback: InlineAdVariant): InlineAdVariant {
	const normalized = getAdText(value);
	return normalized && AD_VARIANTS.has(normalized as InlineAdVariant)
		? (normalized as InlineAdVariant)
		: fallback;
}

function getInferredChips(signals: string[]): string[] {
	const blob = signals.join(" ").toLowerCase();
	const chips: string[] = [];
	const add = (label: string, keys: string[]) => {
		if (chips.length < 3 && keys.some((key) => blob.includes(key))) chips.push(label);
	};
	add("Growth", ["growth", "crecimiento"]);
	add("Funnels", ["funnel", "embudo"]);
	add("IA", [" ia ", "inteligencia artificial", "ai ", "chatgpt", "claude", "openai"]);
	add("SEO", ["seo", "search console", "google"]);
	add("Ads", ["ads", "ppc", "paid", "performance"]);
	add("Inbound", ["inbound", "nurturing", "lead"]);
	return chips.length ? chips : ["Estrategia", "Marketing"];
}

function pickHeroVariant(
	signals: string[],
	hasImage: boolean,
	contentFormat = "article",
	hasVideo = false
): string {
	const blob = signals.join(" ").toLowerCase();
	if (hasVideo || contentFormat === "podcast" || contentFormat === "video") return "broadcast";
	if (blob.includes("podcast") || blob.includes("webinar") || blob.includes("video")) return "broadcast";
	if (blob.includes("ia") || blob.includes("ai") || blob.includes("automat")) return "editorial";
	if (blob.includes("funnel") || blob.includes("growth") || blob.includes("ads") || blob.includes("inbound")) {
		return hasImage ? "signal" : "editorial";
	}
	return hasImage ? "signal" : "minimal";
}

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	const inboundLegacyPrefix = "inbound-monsters-";
	if (slug.startsWith(inboundLegacyPrefix)) {
		return Astro.redirect(`/inbound-monsters/${slug.slice(inboundLegacyPrefix.length)}`, 301);
	}
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);
const postData = post.data as unknown as Record<string, unknown>;
const postEdit = post.edit as unknown as Record<string, Record<string, unknown>>;
const heroExcerptEditProps = postEdit.hero_excerpt ?? {};

// Get featured image URL for OG fallback
// The image may have src (external) or meta.storageKey (local)
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	// Check for direct src
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	// Build from storageKey for local images
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}

function getHttpUrl(value: unknown): string | null {
	if (typeof value !== "string") return null;
	const raw = value.trim();
	if (!raw) return null;
	try {
		const url = new URL(raw);
		return url.protocol === "http:" || url.protocol === "https:" ? url.toString() : null;
	} catch {
		return null;
	}
}

function getYouTubeId(url: string): string | null {
	try {
		const parsed = new URL(url);
		const host = parsed.hostname.replace(WWW_PREFIX_REGEX, "");
		if (host === "youtu.be") return parsed.pathname.split("/").find(Boolean) ?? null;
		if (host.endsWith("youtube.com")) {
			if (parsed.pathname.startsWith("/shorts/") || parsed.pathname.startsWith("/embed/")) {
				const pathParts = parsed.pathname.split("/").filter(Boolean);
				return pathParts[1] ?? null;
			}
			return parsed.searchParams.get("v");
		}
		return null;
	} catch {
		return null;
	}
}

function getVimeoId(url: string): string | null {
	try {
		const parsed = new URL(url);
		const host = parsed.hostname.replace(WWW_PREFIX_REGEX, "");
		if (!host.endsWith("vimeo.com")) return null;
		const pathParts = parsed.pathname.split("/");
		for (let index = pathParts.length - 1; index >= 0; index--) {
			const part = pathParts[index];
			if (VIMEO_NUMERIC_PATH_PART_REGEX.test(part)) return part;
		}
		return null;
	} catch {
		return null;
	}
}

function getHeroVideoEmbedUrl(url: string): string | null {
	const youtubeId = getYouTubeId(url);
	if (youtubeId) return `https://www.youtube-nocookie.com/embed/${youtubeId}`;
	const vimeoId = getVimeoId(url);
	if (vimeoId) return `https://player.vimeo.com/video/${vimeoId}`;
	if (DIRECT_VIDEO_URL_REGEX.test(url)) return url;
	return null;
}

function getHeroVideoThumbnailUrl(url: string): string | undefined {
	const youtubeId = getYouTubeId(url);
	return youtubeId ? `https://i.ytimg.com/vi/${youtubeId}/maxresdefault.jpg` : undefined;
}

function getCssSafeObjectPosition(value: unknown): string | null {
	if (typeof value !== "string") return null;
	const normalized = value.trim().replace(WHITESPACE_REGEX, " ");
	return normalized.length <= 40 && OBJECT_POSITION_REGEX.test(normalized) ? normalized : null;
}

function numberToPercent(value: unknown): string | null {
	if (typeof value !== "number" || !Number.isFinite(value)) return null;
	const percent = Math.abs(value) <= 1 ? value * 100 : value;
	return `${Math.max(0, Math.min(100, Math.round(percent)))}%`;
}

function getPointPosition(source: Record<string, unknown> | undefined): string | null {
	if (!source) return null;
	const x = numberToPercent(source.focusX ?? source.hotspotX ?? source.x);
	const y = numberToPercent(source.focusY ?? source.hotspotY ?? source.y);
	return x && y ? `${x} ${y}` : null;
}

function getHeroImageObjectPosition(data: Record<string, unknown>, img: unknown): string {
	const fieldX = numberToPercent(data.hero_image_focus_x);
	const fieldY = numberToPercent(data.hero_image_focus_y);
	if (fieldX && fieldY) return `${fieldX} ${fieldY}`;

	if (!img || typeof img !== "object") return "50% 50%";
	const image = img as Record<string, unknown>;
	const meta = image.meta as Record<string, unknown> | undefined;
	const focus = image.focus as Record<string, unknown> | undefined;
	const hotspot = image.hotspot as Record<string, unknown> | undefined;
	const metaFocus = meta?.focus as Record<string, unknown> | undefined;
	const metaHotspot = meta?.hotspot as Record<string, unknown> | undefined;
	const explicitPosition = [
		image.objectPosition,
		image.object_position,
		image.focus,
		meta?.objectPosition,
		meta?.object_position,
		meta?.focus,
	]
		.map(getCssSafeObjectPosition)
		.find(Boolean);
	return (
		explicitPosition ??
		getPointPosition(image) ??
		getPointPosition(meta) ??
		getPointPosition(focus) ??
		getPointPosition(hotspot) ??
		getPointPosition(metaFocus) ??
		getPointPosition(metaHotspot) ??
		"50% 50%"
	);
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const heroImageObjectPosition = getHeroImageObjectPosition(
	postData,
	post.data.featured_image
);
const rawContentFormat = cleanDeck(postData.content_format);
const contentFormat =
	rawContentFormat === "podcast" || rawContentFormat === "video" ? rawContentFormat : "article";
const heroVideoUrl = getHttpUrl(postData.hero_video_url);
const heroVideoEmbedUrl = heroVideoUrl ? getHeroVideoEmbedUrl(heroVideoUrl) : null;
const rawHeroVideoLayout = cleanDeck(postData.hero_video_layout);
const heroVideoLayout =
	heroVideoEmbedUrl && rawHeroVideoLayout === "video-feature" ? "video-feature" : "video-card";
const heroVideoCaption = cleanDeck(postData.hero_video_caption);
const hasHeroVideo = Boolean(heroVideoEmbedUrl);
const isHeroVideoFeature = hasHeroVideo && heroVideoLayout === "video-feature";
const isDirectHeroVideo =
	Boolean(heroVideoEmbedUrl) && DIRECT_VIDEO_URL_REGEX.test(heroVideoEmbedUrl ?? "");
const videoThumbnailUrl = heroVideoUrl ? getHeroVideoThumbnailUrl(heroVideoUrl) : undefined;
const heroGlowImageUrl = featuredImageUrl ?? videoThumbnailUrl;
const heroImageCssUrl = heroGlowImageUrl ? `url(${JSON.stringify(heroGlowImageUrl)})` : null;
const heroMediaStyle = `--hero-image-position: ${heroImageObjectPosition};${
	heroImageCssUrl ? ` --hero-image-url: ${heroImageCssUrl};` : ""
}`;
const heroVideoEditProps = postEdit.hero_video_url ?? {};
const heroVideoCaptionEditProps = postEdit.hero_video_caption ?? {};

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle: "Andrés Ospina",
	siteUrl: Astro.url.origin,
	path: `/${slug}`,
	defaultOgImage: heroGlowImageUrl,
});

// Article schema (JSON-LD)
const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: post.data.title,
	description: post.data.excerpt ?? seo.description ?? "",
	image: heroGlowImageUrl,
	author: {
		"@type": "Person",
		"@id": "https://andresospina.co/#person",
		name: "Andrés Ospina",
		url: "https://andresospina.co/sobre-mi",
	},
	publisher: {
		"@type": "Person",
		"@id": "https://andresospina.co/#person",
		name: "Andrés Ospina",
	},
	datePublished: post.data.publishedAt?.toISOString() ?? null,
	dateModified: post.data.updatedAt.toISOString(),
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": `${Astro.url.origin}/${slug}`,
	},
	inLanguage: "es-CO",
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "Inicio", item: Astro.url.origin },
		{ "@type": "ListItem", position: 2, name: "Artículos", item: `${Astro.url.origin}/blog` },
		{ "@type": "ListItem", position: 3, name: post.data.title, item: `${Astro.url.origin}/${slug}` },
	],
};

// Get tags AND categories for this post
// Note: post.id is the slug, post.data.id is the database ULID
const tags = await getEntryTerms("posts", post.data.id, "tag");
const categories = await getEntryTerms("posts", post.data.id, "category").catch(() => []);

// Get reading time
const readingTime = getReadingTime(post.data.content);

// Pick inline ad variant from post terms + slug + title as fallback signals
const adSignals = [
	...tags.map((t: { slug: string }) => t.slug),
	...(categories as { slug: string }[]).map((c) => c.slug),
	slug,
	post.data.title ?? "",
];
const adVariant = pickAdVariant(adSignals);
const heroAdModeRaw = getAdText(postData.hero_ad_mode);
const heroAdMode = heroAdModeRaw === "custom" || heroAdModeRaw === "hidden" ? heroAdModeRaw : "auto";
const heroAdVariant = getAdVariant(postData.hero_ad_variant, adVariant);
const heroAdOverrideDraft: InlineAdOverride = {
	heroEyebrow: getAdText(postData.hero_ad_eyebrow),
	heroTitle: getAdText(postData.hero_ad_title),
	heroCta: getAdText(postData.hero_ad_cta),
	url: getAdText(postData.hero_ad_url),
	coverLabel: getAdText(postData.hero_ad_cover_label),
};
const hasHeroAdOverride = Object.values(heroAdOverrideDraft).some(Boolean);
const heroAdOverride = heroAdMode === "custom" || hasHeroAdOverride ? heroAdOverrideDraft : undefined;
const shouldShowHeroAd = heroAdMode !== "hidden";

// Normalize inline ads: cap at MAX_ADS per post and dedupe consecutive same-variant blocks.
// Content-level inlineAd blocks (from converted legacy CTAs) take priority; template-level
// injection only fills the remaining slots.
const MAX_ADS = 2;
const rawBlocks = stripInlineTocBlocks(Array.isArray(post.data.content) ? post.data.content : []);
const bodyText = extractText(rawBlocks);
const bodyParagraphs = getBlockTexts(rawBlocks);
const fallbackDeck =
	bodyParagraphs.find((text) => text.length > 110) ??
	(bodyText ? truncateSentence(bodyText, 220) : null);
const heroDeck = cleanDeck(postData.hero_excerpt);
const excerptDeck = cleanDeck(post.data.excerpt);
const articleDeck = heroDeck ?? excerptDeck ?? (fallbackDeck ? truncateSentence(fallbackDeck, 230) : null);
type HeroChip = { label: string; href?: string };

function uniqueHeroChips(chips: HeroChip[]): HeroChip[] {
	const seen = new Set<string>();
	return chips.filter((chip) => {
		const key = chip.label.trim().toLowerCase();
		if (!key || seen.has(key)) return false;
		seen.add(key);
		return true;
	});
}

const categoryChips = (categories as { slug: string; label: string }[]).map((term) => ({
	label: term.label,
	href: `/category/${term.slug}`,
}));
const tagChips = (tags as { slug: string; label: string }[]).map((term) => ({
	label: term.label,
	href: term.slug === "inbound-monsters" ? "/inbound-monsters" : `/tag/${term.slug}`,
}));
const formatChip =
	contentFormat === "podcast" ? "Podcast" : contentFormat === "video" ? "Video" : null;
const rawHeroChips: HeroChip[] = [
	...(formatChip ? [{ label: formatChip, href: contentFormat === "podcast" ? "/category/podcast" : undefined }] : []),
	...categoryChips,
	...tagChips,
];
const heroChips = uniqueHeroChips(
	rawHeroChips.length ? rawHeroChips : getInferredChips(adSignals).map((label) => ({ label }))
).slice(0, 3);
const heroVariant = pickHeroVariant(
	adSignals,
	Boolean(heroGlowImageUrl),
	contentFormat,
	hasHeroVideo
);
const heroTitleWordCount = post.data.title.trim().split(/\s+/).filter(Boolean).length;
const heroTitleLengthClass = post.data.title.length > 68 || heroTitleWordCount > 9 ? "post-hero--long-title" : "";
const heroAdDensity = heroTitleLengthClass ? "compact" : "default";
const heroVideoClass = hasHeroVideo ? `post-hero--video post-hero--${heroVideoLayout}` : "";

const videoSchema = heroVideoEmbedUrl
	? {
			"@context": "https://schema.org",
			"@type": "VideoObject",
			name: post.data.title,
			description: articleDeck ?? seo.description ?? post.data.title,
			thumbnailUrl: heroGlowImageUrl,
			uploadDate: post.data.publishedAt?.toISOString() ?? post.data.updatedAt.toISOString(),
			embedUrl: heroVideoEmbedUrl,
			contentUrl: heroVideoUrl,
			inLanguage: "es-CO",
		}
	: null;

type AdBlock = { _type: "inlineAd"; _key?: string; variant?: string };
const isAd = (b: unknown): b is AdBlock =>
	typeof b === "object" && b !== null && (b as { _type?: unknown })._type === "inlineAd";

// Pass 1: dedupe consecutive same-variant ads and cap total content ads at MAX_ADS
const dedupedBlocks: unknown[] = [];
let contentAdCount = 0;
let prevVariant: string | undefined;
for (const block of rawBlocks) {
	if (isAd(block)) {
		if (contentAdCount >= MAX_ADS) continue;
		if (block.variant && block.variant === prevVariant) continue;
		contentAdCount++;
		prevVariant = block.variant;
		dedupedBlocks.push(block);
	} else {
		dedupedBlocks.push(block);
		prevVariant = undefined;
	}
}

const contentBlocks = dedupedBlocks;
const shouldInjectTemplateAd = contentAdCount < MAX_ADS;
const splitAt = Math.max(1, Math.ceil(contentBlocks.length * 0.4));
const contentFirstHalf = contentBlocks.slice(0, splitAt);
const contentSecondHalf = contentBlocks.slice(splitAt);
const hasSecondHalf = contentSecondHalf.length > 0;

// Get other posts for "More posts" section, with their tags
// Fetch a few extra in case the current post is among them
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);

// Fetch tags for related posts (bylines are already hydrated by getEmDashCollection)
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const postTags = await getEntryTerms("posts", p.data.id, "tag");
		const postBylines = p.data.bylines ?? [];
		return { post: p, tags: postTags, bylines: postBylines };
	})
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString("es-ES", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;
const currentPostUrl = `${Astro.url.origin}/${slug}`;
const isPodcastFeatureHero = isHeroVideoFeature && contentFormat === "podcast";
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
	jsonLd={[articleSchema, breadcrumbSchema, ...(videoSchema ? [videoSchema] : [])]}
>
	<div class="read-progress" id="read-progress" aria-hidden="true"></div>

	<section class={`hero post-hero post-hero--${heroVariant} ${heroTitleLengthClass} ${heroVideoClass}`} data-headbar-theme="dark">
		<div class="c">
			<nav class="breadcrumb post-hero-breadcrumb">
				<a href="/">Inicio</a> › <a href="/blog">Artículos</a> › {post.data.title}
			</nav>
			{
				isHeroVideoFeature ? (
					isPodcastFeatureHero ? (
