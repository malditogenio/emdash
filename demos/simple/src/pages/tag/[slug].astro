---
import { getTerm, getEmDashCollection, getEntryTerms, decodeSlug } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("tag", slug) : null;

if (!term) {
	return Astro.redirect("/404");
}

const { entries: posts } = await getEmDashCollection("posts", {
	where: { tag: term.slug },
	orderBy: { published_at: "desc" },
});

// Fetch tags for display on each post card
const filteredPosts = await Promise.all(
	posts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return { post, tags };
	})
);

const isSeriesArchive = term.slug === "inbound-monsters";
const archiveLabel = isSeriesArchive ? "Serie" : "Etiqueta";
const archiveUnit = isSeriesArchive
	? filteredPosts.length === 1 ? "episodio" : "episodios"
	: filteredPosts.length === 1 ? "artículo" : "artículos";
---

<Base
	title={`${term.label} | Andrés Ospina`}
	description={`Archivo de ${term.label}`}
>
	<section class="archive-section">
		<header class="archive-header">
			<span class="archive-label">{archiveLabel}</span>
			<h1 class="archive-title">{term.label}</h1>
			<p class="archive-count">
				{filteredPosts.length}
				{archiveUnit}
			</p>
		</header>

		{
			filteredPosts.length === 0 ? (
				<p class="no-posts">Todavía no hay artículos con esta etiqueta.</p>
			) : (
				<div class="posts-grid">
					{filteredPosts.map(({ post, tags }) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
						/>
					))}
				</div>
			)
		}
	</section>
</Base>
