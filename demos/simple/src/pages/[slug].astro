---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
	decodeSlug,
} from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import InlineAd, { type InlineAdVariant } from "../components/InlineAd.astro";
import { extractText, getReadingTime } from "../utils/reading-time";

const TRAILING_PUNCTUATION_REGEX = /[,\s;:]+$/;
const WHITESPACE_REGEX = /\s+/g;
const OBJECT_POSITION_REGEX =
	/^(?:-?\d+(?:\.\d+)?%?|left|center|right|top|bottom)(?:\s+(?:-?\d+(?:\.\d+)?%?|left|center|right|top|bottom))?$/i;

function pickAdVariant(signals: string[]): InlineAdVariant {
	const blob = signals.join(" ").toLowerCase();
	const hasAny = (keys: string[]) => keys.some((k) => blob.includes(k));
	if (
		hasAny([
			"ai",
			" ia ",
			"inteligencia artificial",
			"inteligencia-artificial",
			"automatizacion",
			"claude",
			"chatgpt",
			"llm",
			"agentes-ia",
			"gpt",
			"openai",
			"gemini",
			"prompt",
		])
	)
		return "ia";
	if (hasAny(["growth-marketing", "performance-marketing", "ppc", "abm", "pipeline", "growth", "funnel"]))
		return "growth";
	if (hasAny(["inbound-marketing", "inbound", "agencias", "agencia"]))
		return "agencias";
	if (hasAny(["conferencias", "conferencia", "evento", "speaker", "keynote", "charla"]))
		return "conferencias";
	return "catchall";
}

function getBlockTexts(blocks: unknown[]): string[] {
	return blocks
		.filter((block): block is { _type: string; style?: string; children?: unknown[] } =>
			typeof block === "object" && block !== null && (block as { _type?: unknown })._type === "block"
		)
		.filter((block) => !block.style || block.style === "normal")
		.map((block) =>
			(block.children ?? [])
				.filter((child): child is { _type: string; text: string } =>
					typeof child === "object" &&
					child !== null &&
					(child as { _type?: unknown })._type === "span" &&
					typeof (child as { text?: unknown }).text === "string"
				)
				.map((child) => child.text)
				.join("")
				.trim()
		)
		.filter(Boolean);
}

function truncateSentence(text: string, maxLength: number): string {
	if (text.length <= maxLength) return text;
	const sliced = text.slice(0, maxLength).trim();
	const lastStop = Math.max(sliced.lastIndexOf("."), sliced.lastIndexOf("?"), sliced.lastIndexOf("!"));
	if (lastStop > maxLength * 0.55) return sliced.slice(0, lastStop + 1);
	return `${sliced.replace(TRAILING_PUNCTUATION_REGEX, "")}...`;
}

function getInferredChips(signals: string[]): string[] {
	const blob = signals.join(" ").toLowerCase();
	const chips: string[] = [];
	const add = (label: string, keys: string[]) => {
		if (chips.length < 3 && keys.some((key) => blob.includes(key))) chips.push(label);
	};
	add("Growth", ["growth", "crecimiento"]);
	add("Funnels", ["funnel", "embudo"]);
	add("IA", [" ia ", "inteligencia artificial", "ai ", "chatgpt", "claude", "openai"]);
	add("SEO", ["seo", "search console", "google"]);
	add("Ads", ["ads", "ppc", "paid", "performance"]);
	add("Inbound", ["inbound", "nurturing", "lead"]);
	return chips.length ? chips : ["Estrategia", "Marketing"];
}

function pickHeroVariant(signals: string[], hasImage: boolean): string {
	const blob = signals.join(" ").toLowerCase();
	if (blob.includes("podcast") || blob.includes("webinar") || blob.includes("video")) return "broadcast";
	if (blob.includes("ia") || blob.includes("ai") || blob.includes("automat")) return "editorial";
	if (blob.includes("funnel") || blob.includes("growth") || blob.includes("ads") || blob.includes("inbound")) {
		return hasImage ? "signal" : "editorial";
	}
	return hasImage ? "signal" : "minimal";
}

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

// Get featured image URL for OG fallback
// The image may have src (external) or meta.storageKey (local)
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	// Check for direct src
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	// Build from storageKey for local images
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}

function getCssSafeObjectPosition(value: unknown): string | null {
	if (typeof value !== "string") return null;
	const normalized = value.trim().replace(WHITESPACE_REGEX, " ");
	return normalized.length <= 40 && OBJECT_POSITION_REGEX.test(normalized) ? normalized : null;
}

function numberToPercent(value: unknown): string | null {
	if (typeof value !== "number" || !Number.isFinite(value)) return null;
	const percent = Math.abs(value) <= 1 ? value * 100 : value;
	return `${Math.max(0, Math.min(100, Math.round(percent)))}%`;
}

function getPointPosition(source: Record<string, unknown> | undefined): string | null {
	if (!source) return null;
	const x = numberToPercent(source.focusX ?? source.hotspotX ?? source.x);
	const y = numberToPercent(source.focusY ?? source.hotspotY ?? source.y);
	return x && y ? `${x} ${y}` : null;
}

function getHeroImageObjectPosition(data: Record<string, unknown>, img: unknown): string {
	const fieldX = numberToPercent(data.hero_image_focus_x);
	const fieldY = numberToPercent(data.hero_image_focus_y);
	if (fieldX && fieldY) return `${fieldX} ${fieldY}`;

	if (!img || typeof img !== "object") return "50% 50%";
	const image = img as Record<string, unknown>;
	const meta = image.meta as Record<string, unknown> | undefined;
	const focus = image.focus as Record<string, unknown> | undefined;
	const hotspot = image.hotspot as Record<string, unknown> | undefined;
	const metaFocus = meta?.focus as Record<string, unknown> | undefined;
	const metaHotspot = meta?.hotspot as Record<string, unknown> | undefined;
	const explicitPosition = [
		image.objectPosition,
		image.object_position,
		image.focus,
		meta?.objectPosition,
		meta?.object_position,
		meta?.focus,
	]
		.map(getCssSafeObjectPosition)
		.find(Boolean);
	return (
		explicitPosition ??
		getPointPosition(image) ??
		getPointPosition(meta) ??
		getPointPosition(focus) ??
		getPointPosition(hotspot) ??
		getPointPosition(metaFocus) ??
		getPointPosition(metaHotspot) ??
		"50% 50%"
	);
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const heroImageObjectPosition = getHeroImageObjectPosition(
	post.data as unknown as Record<string, unknown>,
	post.data.featured_image
);
const heroImageCssUrl = featuredImageUrl ? `url(${JSON.stringify(featuredImageUrl)})` : null;

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle: "Andrés Ospina",
	siteUrl: Astro.url.origin,
	path: `/${slug}`,
	defaultOgImage: featuredImageUrl,
});

// Article schema (JSON-LD)
const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: post.data.title,
	description: post.data.excerpt ?? seo.description ?? "",
	image: featuredImageUrl,
	author: {
		"@type": "Person",
		"@id": "https://andresospina.co/#person",
		name: "Andrés Ospina",
		url: "https://andresospina.co/sobre-mi",
	},
	publisher: {
		"@type": "Person",
		"@id": "https://andresospina.co/#person",
		name: "Andrés Ospina",
	},
	datePublished: post.data.publishedAt?.toISOString() ?? null,
	dateModified: post.data.updatedAt.toISOString(),
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": `${Astro.url.origin}/${slug}`,
	},
	inLanguage: "es-CO",
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "Inicio", item: Astro.url.origin },
		{ "@type": "ListItem", position: 2, name: "Artículos", item: `${Astro.url.origin}/blog` },
		{ "@type": "ListItem", position: 3, name: post.data.title, item: `${Astro.url.origin}/${slug}` },
	],
};

// Get tags AND categories for this post
// Note: post.id is the slug, post.data.id is the database ULID
const tags = await getEntryTerms("posts", post.data.id, "tag");
const categories = await getEntryTerms("posts", post.data.id, "category").catch(() => []);

// Get reading time
const readingTime = getReadingTime(post.data.content);

// Pick inline ad variant from post terms + slug + title as fallback signals
const adSignals = [
	...tags.map((t: { slug: string }) => t.slug),
	...(categories as { slug: string }[]).map((c) => c.slug),
	slug,
	post.data.title ?? "",
];
const adVariant = pickAdVariant(adSignals);

// Normalize inline ads: cap at MAX_ADS per post and dedupe consecutive same-variant blocks.
// Content-level inlineAd blocks (from converted legacy CTAs) take priority; template-level
// injection only fills the remaining slots.
const MAX_ADS = 2;
const rawBlocks = Array.isArray(post.data.content) ? post.data.content : [];
const bodyText = extractText(post.data.content);
const bodyParagraphs = getBlockTexts(rawBlocks);
const fallbackDeck =
	bodyParagraphs.find((text) => text.length > 110) ??
	(bodyText ? truncateSentence(bodyText, 220) : null);
const articleDeck = post.data.excerpt || (fallbackDeck ? truncateSentence(fallbackDeck, 230) : null);
const termChips = [...categories, ...tags].map((term) => term.label).filter(Boolean);
const heroChips = (termChips.length ? termChips : getInferredChips(adSignals)).slice(0, 3);
const heroVariant = pickHeroVariant(adSignals, Boolean(featuredImageUrl));
const heroTitleLengthClass = post.data.title.length > 82 ? "post-hero--long-title" : "";

type AdBlock = { _type: "inlineAd"; _key?: string; variant?: string };
const isAd = (b: unknown): b is AdBlock =>
	typeof b === "object" && b !== null && (b as { _type?: unknown })._type === "inlineAd";

// Pass 1: dedupe consecutive same-variant ads and cap total content ads at MAX_ADS
const dedupedBlocks: unknown[] = [];
let contentAdCount = 0;
let prevVariant: string | undefined;
for (const block of rawBlocks) {
	if (isAd(block)) {
		if (contentAdCount >= MAX_ADS) continue;
		if (block.variant && block.variant === prevVariant) continue;
		contentAdCount++;
		prevVariant = block.variant;
		dedupedBlocks.push(block);
	} else {
		dedupedBlocks.push(block);
		prevVariant = undefined;
	}
}

const contentBlocks = dedupedBlocks;
const shouldInjectTemplateAd = contentAdCount < MAX_ADS;
const splitAt = Math.max(1, Math.ceil(contentBlocks.length * 0.4));
const contentFirstHalf = contentBlocks.slice(0, splitAt);
const contentSecondHalf = contentBlocks.slice(splitAt);
const hasSecondHalf = contentSecondHalf.length > 0;

// Get other posts for "More posts" section, with their tags
// Fetch a few extra in case the current post is among them
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);

// Fetch tags for related posts (bylines are already hydrated by getEmDashCollection)
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const postTags = await getEntryTerms("posts", p.data.id, "tag");
		const postBylines = p.data.bylines ?? [];
		return { post: p, tags: postTags, bylines: postBylines };
	})
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString("es-ES", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
	jsonLd={[articleSchema, breadcrumbSchema]}
>
	<div class="read-progress" id="read-progress" aria-hidden="true"></div>

	<section class={`hero post-hero post-hero--${heroVariant} ${heroTitleLengthClass}`} data-headbar-theme="dark">
		<div class="c">
			<nav class="breadcrumb post-hero-breadcrumb">
				<a href="/">Inicio</a> › <a href="/blog">Artículos</a> › {post.data.title}
			</nav>
			<div class="post-hero-grid">
				{
					post.data.featured_image && featuredImageUrl && (
						<figure
							class="article-hero"
							style={`--hero-image-position: ${heroImageObjectPosition}; --hero-image-url: ${heroImageCssUrl};`}
							{...post.edit.featured_image}
						>
							<img
								src={featuredImageUrl}
								alt={post.data.title}
								loading="eager"
								fetchpriority="high"
								decoding="async"
								style="width: 100%; height: 100%; display: block;"
							/>
						</figure>
					)
				}
				<header class="intro-section">
					<div class="article-kicker">
						{heroChips.map((chip) => (
							<span>{chip}</span>
						))}
					</div>
					<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
					{
						articleDeck && (
							<p class="article-excerpt" {...post.edit.excerpt}>{articleDeck}</p>
						)
					}
					<div class="article-meta">
						<a href="https://andresospina.co/sobre-mi" class="article-meta-author">
							<img
								src="/brand/andres-hero.jpg"
								alt="Andrés Ospina"
								class="article-meta-avatar"
								width="28"
								height="28"
								loading="eager"
							/>
							<span class="article-meta-byline">Andrés Ospina</span>
						</a>
						<span class="meta-dot" />
						{
							publishDate && (
								<>
									<time>{publishDate}</time>
									<span class="meta-dot" />
								</>
							)
						}
						<span>{readingTime} min de lectura</span>
					</div>
				</header>
			</div>
		</div>
	</section>

	<section>
		<div class="c">
			<div class="content-layout">
				<div class="article-column">
					<div class="article article-content">
						<PortableText
							value={contentFirstHalf}
							components={{ type: { inlineAd: InlineAd } }}
						/>
						{shouldInjectTemplateAd && hasSecondHalf && <InlineAd variant={adVariant} />}
						{hasSecondHalf && (
							<PortableText
								value={contentSecondHalf}
								components={{ type: { inlineAd: InlineAd } }}
							/>
						)}
					</div>

					{
						tags.length > 0 && (
							<div class="article-tags">
								{tags.map((t) => (
									<a href={`/tag/${t.slug}`} class="related-link">
										{t.label}
									</a>
								))}
							</div>
						)
					}

					<aside class="author-box">
						<div class="author-box__main">
							<img
								src="/brand/andres-hero.jpg"
								alt="Andrés Ospina"
								class="author-photo"
								width="104"
								height="104"
								loading="lazy"
							/>
							<div class="author-body">
								<div class="author-name">Andrés Ospina</div>
								<div class="author-role">Growth Marketer &amp; Estratega de IA</div>
								<p class="author-bio">
									Construyo sistemas de IA que traen tantos leads que ventas te pedirá que pare (Spoiler: No lo haré).
								</p>
								<div class="author-links">
									<a href="https://www.linkedin.com/in/andresospina/" target="_blank" rel="noopener">LinkedIn</a>
									<span class="author-dot" />
									<a href="https://x.com/malditogenio" target="_blank" rel="noopener">X</a>
									<span class="author-dot" />
									<a href="https://andresospina.co/newsletter" target="_blank" rel="noopener">Newsletter</a>
									<span class="author-dot" />
									<a href="https://andresospina.co/sobre-mi">Sobre mí</a>
								</div>
							</div>
						</div>
					</aside>
				</div>

				<aside class="toc" id="article-toc" aria-label="Tabla de contenido">
					<div class="toc-title">Contenido</div>
					<div class="toc-content" id="toc-content">
						<!-- Populated by JS -->
					</div>
				</aside>
			</div>
		</div>
	</section>

	{
		otherPostsWithTags.length > 0 && (
			<section class="related-posts-section">
				<div class="c">
					<h2 class="related-posts-title">Artículos relacionados</h2>
					<div class="related-posts-grid">
						{otherPostsWithTags.map(({ post: p }) => {
							const thumbUrl = getImageUrl(p.data.featured_image);
							const pReadingTime = getReadingTime(p.data.content);
							return (
								<a href={`/${p.id}`} class="related-post-card">
									<div class="related-post-media">
										{thumbUrl ? (
											<img
												src={thumbUrl}
												alt={p.data.title}
												loading="lazy"
												decoding="async"
												width="400"
												height="225"
											/>
										) : (
											<div class="related-post-placeholder" aria-hidden="true"></div>
										)}
									</div>
									<div class="related-post-body">
										<div class="related-post-title">{p.data.title}</div>
										{p.data.excerpt && (
											<div class="related-post-excerpt">{p.data.excerpt}</div>
										)}
										<div class="related-post-meta">{pReadingTime} min de lectura</div>
									</div>
								</a>
							);
						})}
					</div>
				</div>
			</section>
		)
	}

	<section class="more-link-section">
		<div class="c">
			<a href="/blog" class="more-link">← Ver todos los artículos</a>
		</div>
	</section>

	<script>
		function revealRelatedCard(el: Element) {
			el.classList.add("is-visible");
		}

		// Build a hierarchical TOC: H2 top-level, H3 nested and only visible when
		// its parent H2 section is active (progressive disclosure, not wall-of-text).
		function buildToc() {
			const content = document.querySelector(".article-content");
			const tocContainer = document.getElementById("toc-content");
			const tocEl = document.getElementById("article-toc");
			if (!content || !tocContainer || !tocEl) return;

			const headings = [...content.querySelectorAll("h2, h3")] as HTMLElement[];
			if (headings.length === 0) {
				tocEl.style.display = "none";
				return;
			}

			const list = document.createElement("ul");
			list.className = "toc-list";

			type LinkRef = {
				heading: HTMLElement;
				link: HTMLAnchorElement;
				li: HTMLLIElement;
				parentH2Li: HTMLLIElement | null;
			};
			const links: LinkRef[] = [];
			let currentH2Li: HTMLLIElement | null = null;
			let currentH2Children: HTMLUListElement | null = null;

			headings.forEach((heading, index) => {
				if (!heading.id) heading.id = `heading-${index}`;
				const isH2 = heading.tagName === "H2";

				const li = document.createElement("li");
				li.className = `toc-item toc-item--${isH2 ? "h2" : "h3"}`;
				li.dataset.headingId = heading.id;

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = `toc-link toc-link--${isH2 ? "h2" : "h3"}`;
				link.textContent = heading.textContent;
				li.appendChild(link);

				if (isH2) {
					const childrenUl = document.createElement("ul");
					childrenUl.className = "toc-children";
					li.appendChild(childrenUl);
					list.appendChild(li);
					currentH2Li = li;
					currentH2Children = childrenUl;
					links.push({ heading, link, li, parentH2Li: null });
				} else if (currentH2Li && currentH2Children) {
					currentH2Children.appendChild(li);
					links.push({ heading, link, li, parentH2Li: currentH2Li });
				} else {
					// Orphan h3 (article starts with h3) — render at top level
					list.appendChild(li);
					links.push({ heading, link, li, parentH2Li: null });
				}
			});

			tocContainer.appendChild(list);

			function setActive(activeId: string | null) {
				links.forEach((l) => l.link.classList.remove("active"));
				list.querySelectorAll(".toc-item.is-open").forEach((el) =>
					el.classList.remove("is-open"),
				);
				if (!activeId) return;
				const info = links.find((l) => l.heading.id === activeId);
				if (!info) return;
				info.link.classList.add("active");
				// Expand parent H2 whose section contains this heading
				const parentH2 = info.parentH2Li ?? info.li;
				parentH2.classList.add("is-open");
			}

			// Map each content element to its closest preceding H2/H3 id
			const contentElements = new Map<Element, string>();
			let cursor: string | null = null;
			[...content.children].forEach((el) => {
				if (el.id && (el.tagName === "H2" || el.tagName === "H3")) {
					cursor = el.id;
				}
				if (cursor) contentElements.set(el, cursor);
			});

			const visible = new Set<Element>();
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) visible.add(entry.target);
						else visible.delete(entry.target);
					});
					const firstVisible = [...contentElements.entries()].find(
						([el]) => visible.has(el),
					);
					setActive(firstVisible?.[1] ?? null);
				},
				{
					rootMargin: `-${getComputedStyle(document.documentElement).scrollPaddingTop || "80px"} 0px -80% 0px`,
				},
			);

			contentElements.forEach((_, el) => observer.observe(el));
		}

		buildToc();

		// Scroll-triggered reveal for related post cards only (honors prefers-reduced-motion).
		// InlineAd cards show by default — scroll-reveal caused gaps on hash landings and quick scroll.
		(function () {
			const prefersReduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
			const cards = document.querySelectorAll(".related-post-card");

			if (prefersReduced) {
				cards.forEach(revealRelatedCard);
				return;
			}

			if (cards.length) {
				const cardObs = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								const index = [...cards].indexOf(entry.target as Element);
								(entry.target as HTMLElement).style.transition =
									`opacity 0.55s cubic-bezier(0.25, 1, 0.5, 1) ${index * 90}ms, transform 0.55s cubic-bezier(0.25, 1, 0.5, 1) ${index * 90}ms, box-shadow 0.2s, border-color 0.2s`;
								revealRelatedCard(entry.target);
								cardObs.unobserve(entry.target);
							}
						});
					},
					{ rootMargin: "0px 0px -10% 0px" }
				);
				cards.forEach((c) => cardObs.observe(c));
			}
		})();

		// Reading progress bar
		(function () {
			const bar = document.getElementById("read-progress") as HTMLElement | null;
			const article = document.querySelector(".article-content") as HTMLElement | null;
			if (!bar || !article) return;
			let raf = 0;
			function update() {
				const rect = article!.getBoundingClientRect();
				const total = rect.height - window.innerHeight + 240;
				const scrolled = -rect.top + 140;
				const pct = Math.max(0, Math.min(100, (scrolled / total) * 100));
				bar!.style.width = pct + "%";
				raf = 0;
			}
			addEventListener(
				"scroll",
				() => {
					if (!raf) raf = requestAnimationFrame(update);
				},
				{ passive: true }
			);
			update();
		})();
	</script>
</Base>
